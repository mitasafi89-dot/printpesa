# ---- Engine ----
PORT=8080
# Provably-fair daily server seed (hex). In prod this is generated & committed daily.
SERVER_SEED=replace-with-daily-hex-seed

# ---- Persistence (Postgres / Supabase) ----
# When set, the engine uses the atomic RPCs (fn_open_position / fn_settle_position)
# via the service-role connection. When unset, it runs an in-memory store (dev only).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres

# ---- Auth (self-issued HS256 tokens; verified on the socket and REST) ----
# Auth is self-managed (phone + password, no OTP/Supabase Auth). The API's AuthService SIGNS
# HS256 tokens with SUPABASE_JWT_SECRET and the engine/API verify with the same secret.
# REQUIRED for apps/api (token issuance) and whenever DATABASE_URL is set (fail-closed).
SUPABASE_JWT_SECRET=
# Asymmetric JWKS verification (engine WS only) — cannot verify the API's self-issued HS256
# tokens, so set SUPABASE_JWT_SECRET when running apps/api:
SUPABASE_JWKS_URL=
# Optional issuer/audience pinning (must match on both the issuer and the verifier):
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUD=authenticated
