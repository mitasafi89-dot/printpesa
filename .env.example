# ---- Engine ----
PORT=8080
# Provably-fair daily server seed (hex). In prod this is generated & committed daily.
SERVER_SEED=replace-with-daily-hex-seed

# ---- Persistence (Postgres / Supabase) ----
# When set, the engine uses the atomic RPCs (fn_open_position / fn_settle_position)
# via the service-role connection. When unset, it runs an in-memory store (dev only).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres

# ---- Auth (verify Supabase JWTs on the socket) ----
# Provide ONE of the following. Required whenever DATABASE_URL is set (fail-closed).
# Legacy symmetric secret (Supabase project JWT secret):
SUPABASE_JWT_SECRET=
# OR asymmetric verification via JWKS (newer Supabase signing keys):
SUPABASE_JWKS_URL=
# Optional issuer/audience pinning:
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUD=authenticated
